{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "1180px",
			"wideSize": "1340px"
		},
		"color": {
			"defaultPalette": false,
			"palette": [
				{ "slug": "base", "color": "#ffffff", "name": "White" },
				{ "slug": "surface", "color": "#f4f8fc", "name": "Surface" },
				{ "slug": "contrast", "color": "#0e2a47", "name": "Navy" },
				{ "slug": "primary", "color": "#1763e6", "name": "Primary Blue" },
				{ "slug": "primary-dark", "color": "#0f4fbd", "name": "Primary Dark" },
				{ "slug": "accent", "color": "#ff7a18", "name": "Accent Orange" },
				{ "slug": "muted", "color": "#5b6b7f", "name": "Muted" },
				{ "slug": "border", "color": "#e2e9f1", "name": "Border" }
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "body",
					"name": "Body",
					"fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
				},
				{
					"slug": "heading",
					"name": "Heading",
					"fontFamily": "'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
				}
			],
			"fontSizes": [
				{ "slug": "small", "size": "0.875rem", "name": "Small" },
				{ "slug": "medium", "size": "1.05rem", "name": "Medium" },
				{ "slug": "large", "size": "1.5rem", "name": "Large" },
				{ "slug": "x-large", "size": "2.25rem", "name": "X-Large" },
				{ "slug": "xx-large", "size": "clamp(2.4rem, 5vw, 3.6rem)", "name": "XX-Large" }
			]
		},
		"spacing": {
			"units": [ "px", "em", "rem", "%", "vw", "vh" ],
			"spacingSizes": [
				{ "slug": "30", "size": "1rem", "name": "1" },
				{ "slug": "40", "size": "1.5rem", "name": "2" },
				{ "slug": "50", "size": "2.5rem", "name": "3" },
				{ "slug": "60", "size": "4rem", "name": "4" },
				{ "slug": "70", "size": "6rem", "name": "5" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "1.05rem",
			"lineHeight": "1.65"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				},
				"color": { "text": "var(--wp--preset--color--contrast)" }
			},
			"link": {
				"color": { "text": "var(--wp--preset--color--primary)" },
				":hover": { "color": { "text": "var(--wp--preset--color--primary-dark)" } }
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text": "#ffffff"
				},
				"typography": { "fontWeight": "600" },
				"border": { "radius": "8px" },
				"spacing": { "padding": { "top": "0.85rem", "bottom": "0.85rem", "left": "1.6rem", "right": "1.6rem" } },
				":hover": { "color": { "background": "#e76a08" } }
			}
		}
	}
}
